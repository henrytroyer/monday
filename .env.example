# Safeguarding Certificates board (child safeguarding certificate files)
# VITE_SAFEGUARDING_BOARD_ID=6616292638
# VITE_SAFEGUARDING_COL_EMAIL=Email
# VITE_SAFEGUARDING_COL_CERTIFICATE=Upload Certificate Here
# VITE_CONTACT_COL_SAFEGUARDING_LINK=link to Safeguarding Certificates (2.0)

# Pastor reference drill-down — extra column titles (comma-separated exact titles)
# VITE_PASTOR_REFERENCE_COLUMNS=Pastor Phone,Reference Comments

# QuickBooks (optional) — run npm run quickbooks:proxy with server env below
# VITE_QUICKBOOKS_PROXY_URL=http://localhost:4041
# Or via Vite dev proxy:
# VITE_QUICKBOOKS_PROXY_URL=/api/quickbooks
# VITE_COL_QUICKBOOKS_INVOICE_ID=QuickBooks Invoice ID

# monday API proxy (local dev) — run npm run monday:proxy in a second terminal
# Uses MONDAY_API_TOKEN server-side; no Board View tunnel required
# VITE_MONDAY_API_PROXY_URL=/api/monday

# Server-side only (quickbooks-proxy + monday-api-proxy + sync) — never expose in Vite client
# QBO_ACCESS_TOKEN=
# QBO_REALM_ID=
# MONDAY_API_TOKEN=

# QuickBooks income watcher — read-only poll → Monday Donations + Contacts (see docs/crm-qbo-income-sync.md)
# QBO_INCOME_SYNC_ENABLED=true
# QBO_INCOME_SYNC_INTERVAL_MS=300000
# QBO_INCOME_LOOKBACK_DAYS=7
# VITE_QBO_INCOME_SYNC_ENABLED=true
# CONTACTS_BOARD_ID=2463183745
# DONATIONS_BOARD_ID=2473175689
# CONTACT_COL_DONATIONS_LINK_ID=link_to_donations
# VITE_DONATION_COL_QBO_TXN_ID=
