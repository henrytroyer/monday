# Copy to .env and adjust. Do not commit .env with secrets.

# Use mock CRM data instead of monday.com (UI development)
VITE_USE_MOCK_DATA=false

# Read-only guard — blocks Application-board write mutations while testing live data
VITE_MONDAY_READ_ONLY=true

# Allow contact profile + tag writes while VITE_MONDAY_READ_ONLY=true (Applications stay protected)
# VITE_CONTACTS_WRITABLE=true

# Allow application status + column writes while VITE_MONDAY_READ_ONLY=true
# VITE_APPLICATIONS_WRITABLE=true

# Allow term-note writes on Applications items while status changes stay read-only
# VITE_APPLICATION_NOTES_WRITABLE=true

# Optional comma-separated board IDs to harvest/watch (defaults to Contacts + Applications)
# VITE_MONDAY_BOARD_IDS=2463183745,1234567890

# Temporary board watcher — polls monday for new updates (remove when multi-page writes ship)
# VITE_MONDAY_WATCH_ENABLED=true
# VITE_MONDAY_WATCH_INTERVAL_MS=60000

# Short-term applications board (Volunteer Service - Short Term)
# VITE_APPLICATIONS_BOARD_ID=2473000031
# Example column overrides when titles differ from CRM defaults (see docs/crm-column-mapping.md):
# VITE_COL_LOCATION_PREFERENCE=i58 Location Preference
# VITE_COL_STATUS=Status ↗️
# VITE_COL_SIGNUP_TIMELINE=Preferred Dates
# VITE_COL_EMAIL=Email Address
# VITE_COL_PHONE=Applicant Phone
# VITE_COL_PARENT_EMAIL=Parent's Email
# VITE_COL_PASTOR_EMAIL=Pastor's Email
# VITE_COL_NOTES=Notes

# Contacts board (master list) — required when VITE_USE_MOCK_DATA=false
# VITE_CONTACTS_BOARD_ID=1234567891
# VITE_CONTACTS_BOARD_NAME=Contacts Test
# VITE_CONTACT_COL_TAGS=Tags
# Force tag writes to legacy Mailchimp column when a separate Tags column exists:
# VITE_CONTACT_COL_TAGS=type
# VITE_CONTACT_COL_TYPE=type
# VITE_CONTACT_COL_EMAIL=Email
# VITE_CONTACT_COL_PROFILE_PHOTO=Profile Photo
# VITE_CONTACT_COL_PASSPORT=Passport Photo
# VITE_CONTACT_COL_FILES=Files
# VITE_CONTACT_COL_QBO_CUSTOMER_ID=QuickBooks Customer ID
# VITE_CONTACT_COL_APPLICATIONS=Applications
# VITE_CONTACT_COL_ADDRESS=Address
# VITE_CONTACT_COL_CITY=City
# VITE_CONTACT_COL_STATE=State
# VITE_CONTACT_COL_ZIP=Zip
# VITE_CONTACT_COL_COUNTRY=Country
# VITE_CONTACT_COL_DATE_OF_BIRTH=Date of birth
# VITE_CONTACT_COL_PASTOR_NAME=Pastor Name
# VITE_CONTACT_COL_PASTOR_EMAIL=Pastor Email
# VITE_CONTACT_COL_PASTOR_PHONE=Pastor Phone
# VITE_CONTACT_COL_CHURCH=Church Name
# VITE_CONTACT_COL_PASTOR_REFERENCE_LINK=Pastor Reference
# VITE_CONTACT_COL_PASTOR_REFERENCE_LINK_ID=link_to_pastors_reference7
# VITE_CONTACT_COL_DONATIONS_LINK=Donations
# VITE_CONTACT_COL_DONATIONS_LINK_ID=link_to_donations

# Donations board — gift history on contact detail (merged with QuickBooks when configured)
# VITE_DONATIONS_BOARD_ID=2473175689
# VITE_DONATION_COL_EMAIL=Donor Email
# VITE_DONATION_COL_DATE=Date
# VITE_DONATION_COL_AMOUNT=Amount
# VITE_DONATION_COL_PROGRAM=Program
# VITE_DONATION_COL_DESIGNATION=Designation

# Column title overrides (must match your Applications board)
# VITE_COL_LOCATION_PREFERENCE=Location Preference
# VITE_COL_LOCATION=Location
# VITE_COL_STATUS=Status
# VITE_COL_SIGNUP_TIMELINE=Signup Timeline
# VITE_COL_HOUSING=Housing
# VITE_COL_ITINERARY=Itinerary Notes
# VITE_COL_ITINERARY_FILES=Itinerary
# VITE_COL_ARRIVAL_DATE=Arrival Date
# VITE_COL_ARRIVAL_TIME=Arrival Time
# VITE_COL_ARRIVAL_AIRPORT=Arrival Airport
# VITE_COL_DEPARTURE_DATE=Departure Date
# VITE_COL_DEPARTURE_TIME=Departure Time
# VITE_COL_DEPARTURE_AIRPORT=Departure Airport
# VITE_COL_ARRIVAL=Arrival
# VITE_COL_COORDINATOR=Coordinator
# VITE_COL_NOTES=Internal Notes
# VITE_COL_EMAIL=Email
# VITE_COL_PARENT_EMAIL=Parent Email
# VITE_COL_PASTOR_EMAIL=Pastor Email
# VITE_COL_OTHER_REFERENCE_EMAILS=Other Reference Emails
# VITE_COL_PHONE=Phone
# VITE_COL_PROFILE_PHOTO=Profile Photo
# VITE_COL_PASSPORT=Passport Photo
# VITE_COL_PASSPORT_NEW=Please upload New Passport
# VITE_COL_RELEASE_FORMS=Release Forms
# VITE_COL_FILES=Files
# VITE_COL_DATE_OF_BIRTH=Birthdate
# VITE_COL_ADDRESS_STREET=Street
