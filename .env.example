# Copy to .env and adjust. NEVER commit .env — it contains secrets.
# Run: npm run setup

# =============================================================================
# DEFAULT: Mock mode (works immediately after clone, no token needed)
# =============================================================================
VITE_USE_MOCK_DATA=true

# =============================================================================
# LIVE monday.com (uncomment block below + add MONDAY_API_TOKEN)
# Requires: npm run dev:live  →  http://localhost:4040
# Each developer creates their own token at monday.com → Developers → API
# =============================================================================
# VITE_USE_MOCK_DATA=false
# VITE_MONDAY_READ_ONLY=true
# VITE_CONTACTS_WRITABLE=true
# VITE_APPLICATION_NOTES_WRITABLE=true
# VITE_CONTACTS_BOARD_ID=2463183745
# VITE_APPLICATIONS_BOARD_ID=2473000031
# VITE_DONATIONS_BOARD_ID=2473175689
# VITE_MONDAY_API_PROXY_URL=/api/monday
# VITE_MONDAY_WATCH_ENABLED=true
# VITE_MONDAY_WATCH_INTERVAL_MS=60000
# MONDAY_API_TOKEN=

# Applications column overrides (match your board titles — see docs/crm-column-mapping.md)
# VITE_COL_LOCATION_PREFERENCE=i58 Location Preference
# VITE_COL_LOCATION=Location
# VITE_COL_STATUS=Status ↗️
# VITE_COL_SIGNUP_TIMELINE=Preferred Dates
# VITE_COL_NOTES=Notes
# VITE_COL_EMAIL=Email Address
# VITE_COL_PARENT_EMAIL=Parent's Email
# VITE_COL_PASTOR_EMAIL=Pastor's Email
# VITE_COL_PHONE=Applicant Phone

# Contacts column link IDs
# VITE_CONTACT_COL_PASTOR_REFERENCE_LINK_ID=link_to_pastors_reference7
# VITE_CONTACT_COL_DONATIONS_LINK_ID=link_to_donations

# Allow application status + column writes while VITE_MONDAY_READ_ONLY=true
# VITE_APPLICATIONS_WRITABLE=true

# Optional comma-separated board IDs to harvest/watch
# VITE_MONDAY_BOARD_IDS=2463183745,2473000031

# Contacts board name (display only)
# VITE_CONTACTS_BOARD_NAME=Contacts

# Contacts column overrides — see docs/crm-contacts.md
# VITE_CONTACT_COL_TAGS=Tags
# VITE_CONTACT_COL_EMAIL=Email
# VITE_CONTACT_COL_PROFILE_PHOTO=Profile Photo
# VITE_CONTACT_COL_QBO_CUSTOMER_ID=QuickBooks Customer ID
# VITE_CONTACT_COL_APPLICATIONS=Applications
# VITE_CONTACT_COL_ADDRESS=Address
# VITE_CONTACT_COL_CITY=City
# VITE_CONTACT_COL_COUNTRY=Country
# VITE_CONTACT_COL_DATE_OF_BIRTH=Date of birth

# Donations board columns
# VITE_DONATION_COL_EMAIL=Donor Email
# VITE_DONATION_COL_DATE=Date
# VITE_DONATION_COL_AMOUNT=Amount
# VITE_DONATION_COL_PROGRAM=Program
# VITE_DONATION_COL_DESIGNATION=Designation

# Safeguarding Certificates board
# VITE_SAFEGUARDING_BOARD_ID=6616292638
# VITE_SAFEGUARDING_COL_EMAIL=Email
# VITE_SAFEGUARDING_COL_CERTIFICATE=Upload Certificate Here

# QuickBooks (optional) — run npm run quickbooks:proxy
# VITE_QUICKBOOKS_PROXY_URL=/api/quickbooks
# VITE_COL_QUICKBOOKS_INVOICE_ID=QuickBooks Invoice ID

# Server-side only — never expose in VITE_ variables
# QBO_ACCESS_TOKEN=
# QBO_REALM_ID=

# Mailchimp sync (npm run sync:contacts)
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# MAILCHIMP_DATACENTER=us1
# MONDAY_BOARD_NAME=Contacts
