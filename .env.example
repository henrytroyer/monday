# Copy to .env and adjust. Do not commit .env with secrets.

# Use mock CRM data instead of monday.com (UI development)
VITE_USE_MOCK_DATA=false

# Read-only guard — blocks all monday write mutations while testing live data
VITE_MONDAY_READ_ONLY=true

# Optional: board id when testing outside Board View (numeric id from board URL)
# VITE_APPLICATIONS_BOARD_ID=1234567890

# Contacts board (master list) — required when VITE_USE_MOCK_DATA=false
# VITE_CONTACTS_BOARD_ID=1234567891
# VITE_CONTACTS_BOARD_NAME=Contacts Test
# VITE_CONTACT_COL_TAGS=Tags
# VITE_CONTACT_COL_EMAIL=Email
# VITE_CONTACT_COL_PROFILE_PHOTO=Profile Photo
# VITE_CONTACT_COL_PASSPORT=Passport Photo
# VITE_CONTACT_COL_FILES=Files
# VITE_CONTACT_COL_QBO_CUSTOMER_ID=QuickBooks Customer ID
# VITE_CONTACT_COL_APPLICATIONS=Applications

# Column title overrides (must match your Applications board)
# VITE_COL_LOCATION_PREFERENCE=Location Preference
# VITE_COL_LOCATION=Location
# VITE_COL_STATUS=Status
# VITE_COL_SIGNUP_TIMELINE=Signup Timeline
# VITE_COL_HOUSING=Housing
# VITE_COL_ITINERARY=Itinerary Notes
# VITE_COL_ITINERARY_FILES=Itinerary
# VITE_COL_ARRIVAL_DATE=Arrival Date
# VITE_COL_ARRIVAL_TIME=Arrival Time
# VITE_COL_ARRIVAL_AIRPORT=Arrival Airport
# VITE_COL_DEPARTURE_DATE=Departure Date
# VITE_COL_DEPARTURE_TIME=Departure Time
# VITE_COL_DEPARTURE_AIRPORT=Departure Airport
# VITE_COL_ARRIVAL=Arrival
# VITE_COL_COORDINATOR=Coordinator
# VITE_COL_NOTES=Internal Notes
# VITE_COL_EMAIL=Email
# VITE_COL_PARENT_EMAIL=Parent Email
# VITE_COL_PASTOR_EMAIL=Pastor Email
# VITE_COL_OTHER_REFERENCE_EMAILS=Other Reference Emails
# VITE_COL_PHONE=Phone
# VITE_COL_PROFILE_PHOTO=Profile Photo
# VITE_COL_FILES=Files

# Pastor reference drill-down — extra column titles (comma-separated exact titles)
# VITE_PASTOR_REFERENCE_COLUMNS=Pastor Phone,Reference Comments

# QuickBooks (optional) — run npm run quickbooks:proxy with server env below
# VITE_QUICKBOOKS_PROXY_URL=http://localhost:4041
# Or via Vite dev proxy:
# VITE_QUICKBOOKS_PROXY_URL=/api/quickbooks
# VITE_COL_QUICKBOOKS_INVOICE_ID=QuickBooks Invoice ID

# monday API proxy (local dev) — run npm run monday:proxy in a second terminal
# Uses MONDAY_API_TOKEN server-side; no Board View tunnel required
# VITE_MONDAY_API_PROXY_URL=/api/monday

# Server-side only (quickbooks-proxy + monday-api-proxy + sync) — never expose in Vite client
# QBO_ACCESS_TOKEN=
# QBO_REALM_ID=
# MONDAY_API_TOKEN=
